# Telegram bot — create one with @BotFather, /newbot
TELEGRAM_BOT_TOKEN=

# Optional but recommended in production. Random string passed to Telegram
# via setWebhook?secret_token=...; verified on every webhook delivery.
TELEGRAM_WEBHOOK_SECRET=

# Public bot handle (without the @). Surfaced in the dashboard so visitors
# can open the bot or scan a QR — must match the username you gave BotFather.
NEXT_PUBLIC_BOT_USERNAME=your_bot_username

# Google Gemini — handles BOTH voice transcription and intent parsing in a
# single API call. Get a free key at https://aistudio.google.com/apikey
# (no payment method required; Gemini 2.5 Flash free tier is plenty for this
# project).
GEMINI_API_KEY=

# Public HTTPS URL of the deployed dashboard. Only needed for
# `npm run bot:set-webhook` when registering the production webhook.
APP_BASE_URL=https://your-app.example

# Postgres connection string. Get a free database at https://neon.tech
# (no credit card needed, scales to zero, generous free tier).
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require
